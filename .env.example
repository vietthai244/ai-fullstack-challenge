# .env.example (repo root)
# Copy to .env and fill in secrets before running `docker compose up` or local dev.
#
# LOCAL DEV:
#   DATABASE_URL=postgres://campaign:campaign@localhost:5432/campaigns
#   REDIS_URL=redis://localhost:6379
#
# DOCKER (docker compose up):
#   DATABASE_URL and REDIS_URL are overridden in docker-compose.yml via the
#   `environment:` block to use Docker service names:
#     DATABASE_URL=postgres://campaign:campaign@postgres:5432/campaigns
#     REDIS_URL=redis://redis:6379
#   You only need to fill in the JWT secrets and other values below.

# PostgreSQL connection URL used by backend (Sequelize CLI + runtime)
# Local dev: use localhost. Docker: overridden by compose to use service name.
DATABASE_URL=postgres://campaign:campaign@localhost:5432/campaigns

# docker-compose postgres service credentials (must match DATABASE_URL above)
POSTGRES_USER=campaign
POSTGRES_PASSWORD=campaign
POSTGRES_DB=campaigns

# Backend runtime env
NODE_ENV=development
LOG_LEVEL=debug

# --- Phase 3 additions (AUTH-01..07) ---
# JWT secrets — MUST be >= 32 chars AND differ. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-at-least-32-random-chars-aaaaaaaaaaa
JWT_REFRESH_SECRET=replace-me-with-a-DIFFERENT-32-char-value-bbbbbbbbbb

# Token lifetimes (jsonwebtoken expiresIn syntax — e.g. '15m', '7d', or seconds)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# bcryptjs cost factor (10 matches Phase 2 demo seeder)
BCRYPT_COST=10

# Redis — Phase 3 denylist; Phase 5 BullMQ uses same REDIS_URL with maxRetriesPerRequest: null
# Local dev: redis://localhost:6379
# Docker: overridden by compose to use service name redis://redis:6379
REDIS_URL=redis://localhost:6379

# HTTP
PORT=3000
